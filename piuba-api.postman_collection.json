{
  "info": {
    "name": "Piuba API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" },
    { "key": "company_id", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Ping",
          "request": { "method": "GET", "url": "{{base_url}}/auth/ping", "auth": { "type": "noauth" } }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.access_token) pm.collectionVariables.set('token', r.access_token);",
                  "if (r.company_id) pm.collectionVariables.set('company_id', r.company_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\",\n  \"company_id\": 1\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": { "method": "GET", "url": "{{base_url}}/auth/me" }
        },
        {
          "name": "Refresh Token",
          "request": { "method": "POST", "url": "{{base_url}}/auth/refresh" }
        },
        {
          "name": "Switch Company",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/switch-company",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"company_id\": 1\n}" }
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{base_url}}/auth/logout" }
        }
      ]
    },
