{
  "info": {
    "_postman_id": "piuba-api-collection-001",
    "name": "Piuba API",
    "description": "Collection gerada a partir da documentação Swagger (OpenAPI) da API Piuba.\n\nBase URL: http://localhost:8005/api\n\n1. Execute **Login** primeiro para obter o token.\n2. O token é salvo automaticamente na variável `token`.\n3. As demais requisições usam Bearer Token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8005/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data && json.data.token) {",
                  "        pm.collectionVariables.set('token', json.data.token);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/login",
            "description": "Autentica o usuário e retorna o token JWT. O token é salvo automaticamente na variável da collection."
          }
        },
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/ping",
            "description": "Verifica se a API está respondendo (requer autenticação)."
          }
        }
      ]
    },
    {
      "name": "Batches",
      "item": [
        {
          "name": "List batches",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/company/batches?page=1&per_page=15",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "company",
                "batches"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "15"
                }
              ]
            },
            "description": "Lista lotes (batches) com paginação."
          }
        },
        {
          "name": "Get batch by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/company/batch/{{batchId}}",
            "description": "Retorna um lote pelo ID. Substitua {{batchId}} pelo UUID."
          }
        },
        {
          "name": "Create batch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"tankId\": \"uuid-do-tanque\",\n    \"name\": \"Lote 01\",\n    \"entryDate\": \"2026-03-01\",\n    \"initialQuantity\": 1000,\n    \"species\": \"Tilápia\",\n    \"cultivation\": \"Intensivo\"\n}"
            },
            "url": "{{baseUrl}}/company/batch",
            "description": "Cria um novo lote."
          }
        },
        {
          "name": "Update batch",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"tankId\": \"uuid-do-tanque\",\n    \"name\": \"Lote 01\",\n    \"entryDate\": \"2026-03-01\",\n    \"initialQuantity\": 1000,\n    \"species\": \"Tilápia\",\n    \"cultivation\": \"Intensivo\"\n}"
            },
            "url": "{{baseUrl}}/company/batch/{{batchId}}",
            "description": "Atualiza um lote. Substitua {{batchId}} pelo UUID."
          }
        },
        {
          "name": "Delete batch",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/company/batch/{{batchId}}",
            "description": "Remove um lote. Substitua {{batchId}} pelo UUID."
          }
        }
      ]
    },
